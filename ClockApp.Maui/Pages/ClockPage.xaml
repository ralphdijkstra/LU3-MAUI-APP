<?xml version="1.0" encoding="utf-8" ?>
<pages:MvvmContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ClockApp.Maui.Controls"
             xmlns:pages="clr-namespace:ClockApp.Maui.Pages"
             xmlns:vm="clr-namespace:ClockApp.Maui.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="ClockApp.Maui.Pages.ClockPage"
             x:TypeArguments="vm:ClockViewModel"
             x:DataType="vm:ClockViewModel"
             Style="{StaticResource TimeOnPage}">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Spacing="0">
            <Border
                BackgroundColor="{StaticResource Surface}"
                StrokeThickness="0"
                HeightRequest="52"
                Padding="16,0,12,0">
                <controls:ClockTitleView BindingContext="{Binding}" VerticalOptions="Center" />
            </Border>

            <BoxView
                HeightRequest="1"
                Color="{StaticResource Border}"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout
                Padding="20"
                Spacing="20">
                
                <Label Text="Clock in" Style="{StaticResource TimeOnTitle}" FontSize="22" />

                <Border Style="{StaticResource TimeOnCard}" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Border
                            HeightRequest="4"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8,8,0,0" />

                        <VerticalStackLayout Padding="24,28" Spacing="16">
                            <VerticalStackLayout IsVisible="{Binding ShowQrEntry}" Spacing="16">
                                <Label Text="{Binding QrScannerHint}" Style="{StaticResource TimeOnSubtitle}" />

                                <Border Stroke="{StaticResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 12" HeightRequest="220">
                                    <zxing:CameraBarcodeReaderView x:Name="BarcodeReader" BarcodesDetected="OnBarcodesDetected" IsDetecting="{Binding IsScanning}" />
                                </Border>

                                <Border Style="{StaticResource TimeOnFormField}">
                                    <Entry
                                        Text="{Binding PairingCode}"
                                        MaxLength="5"
                                        Placeholder="Pairing code"
                                        HorizontalTextAlignment="Center"
                                        FontSize="24"
                                        CharacterSpacing="8"
                                        Style="{StaticResource TimeOnEntry}"
                                        BackgroundColor="Transparent" />
                                </Border>

                                <Button Text="{Binding QrSubmitButtonText}" Command="{Binding SubmitCodeCommand}" IsEnabled="{Binding CanSubmitCode}" Style="{StaticResource TimeOnPrimaryButton}" HorizontalOptions="Fill" />
                            </VerticalStackLayout>

                            <VerticalStackLayout
                                IsVisible="{Binding ShowElapsedTimer}"
                                Spacing="4"
                                Margin="0,0,0,4">
                                <Label
                                    Text="{Binding TimerCaption}"
                                    Style="{StaticResource TimeOnElapsedTimerCaption}" />

                                <Label
                                    Text="{Binding ElapsedDisplay}"
                                    Style="{StaticResource TimeOnElapsedTimer}" />
                            </VerticalStackLayout>

                            <Label
                                Text="{Binding SessionLabel}"
                                IsVisible="{Binding HasSessionLabel}"
                                Style="{StaticResource TimeOnSubtitle}" />

                            <Label
                                Text="{Binding BreakLabel}"
                                IsVisible="{Binding HasBreakLabel}"
                                Style="{StaticResource TimeOnStatusAccent}" />

                            <Label
                                Text="{Binding ErrorMessage}"
                                IsVisible="{Binding HasErrorMessage}"
                                Style="{StaticResource TimeOnError}" />

                            <Label
                                Text="{Binding InfoMessage}"
                                IsVisible="{Binding HasInfoMessage}"
                                Style="{StaticResource TimeOnInfoMessage}" />

                            <VerticalStackLayout IsVisible="{Binding ShowGpsLocationStatus}" Spacing="8" Margin="0,4,0,0">
                                <Label Text="Location status" Style="{StaticResource TimeOnSectionTitle}" Margin="0" />

                                <Border Stroke="{StaticResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16,14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding LocationStatusText}" Style="{StaticResource TimeOnSectionTitle}" FontAttributes="None" Margin="0" />
                                            <Label Text="{Binding WorkLocationName}" IsVisible="{Binding HasWorkLocationName}" Style="{StaticResource TimeOnSubtitle}" Margin="0" />
                                        </VerticalStackLayout>

                                        <ActivityIndicator Grid.Column="1" Color="{StaticResource Primary}" IsRunning="{Binding IsCheckingLocation}" IsVisible="{Binding IsCheckingLocation}" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="12" Margin="0,8,0,0">
                                <Button
                                    Text="Clock in"
                                    IsVisible="{Binding ShowClockIn}"
                                    IsEnabled="{Binding CanClockInAtLocation}"
                                    Command="{Binding ClockInCommand}"
                                    Style="{StaticResource TimeOnPrimaryButton}"
                                    HorizontalOptions="Fill" />

                                <Button
                                    Text="Start break"
                                    IsVisible="{Binding ShowStartBreak}"
                                    Command="{Binding StartBreakCommand}"
                                    Style="{StaticResource TimeOnPrimaryButton}"
                                    HorizontalOptions="Fill" />

                                <Button
                                    Text="End break"
                                    IsVisible="{Binding ShowEndBreak}"
                                    IsEnabled="{Binding EndBreakEnabled}"
                                    Command="{Binding EndBreakCommand}"
                                    Style="{StaticResource TimeOnOutlineButton}"
                                    HorizontalOptions="Fill" />

                                <BoxView
                                    IsVisible="{Binding ShowActionDivider}"
                                    Style="{StaticResource TimeOnDivider}"
                                    Margin="0,4" />

                                <Button
                                    Text="Clock out"
                                    IsVisible="{Binding ShowClockOut}"
                                    IsEnabled="{Binding CanClockOutAtLocation}"
                                    Command="{Binding ClockOutCommand}"
                                    Style="{StaticResource TimeOnMutedButton}"
                                    HorizontalOptions="Fill" />
                            </VerticalStackLayout>

                            <ActivityIndicator
                                Color="{StaticResource Primary}"
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource TimeOnCard}" Padding="24,24">
                    <VerticalStackLayout Spacing="12">
                        <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                            <Label Grid.Column="0" Text="{Binding DayHoursTitle}" Style="{StaticResource TimeOnSectionTitle}" FontSize="18" Margin="0,0,0,0" VerticalOptions="Center" />

                            <Label Grid.Column="2" Text="{Binding DayTotalDuration, StringFormat='Total: {0}'}" IsVisible="{Binding HasDayTotalDuration}" Style="{StaticResource TimeOnSectionTitle}" FontSize="18" FontAttributes="None" VerticalOptions="Center" />
                        </Grid>

                        <ActivityIndicator Color="{StaticResource Primary}" IsRunning="{Binding IsLoadingDayHours}" IsVisible="{Binding IsLoadingDayHours}" HorizontalOptions="Center" />

                        <Label Text="{Binding DayHoursErrorMessage}" IsVisible="{Binding HasDayHoursError}" Style="{StaticResource TimeOnError}" FontSize="13" />

                        <Label Text="No hours yet today." IsVisible="{Binding HasNoDayHours}" Style="{StaticResource TimeOnSubtitle}" />

                        <CollectionView ItemsSource="{Binding DayHours}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:DayHourItemViewModel">
                                    <controls:DayHourItemView BindingContext="{Binding .}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</pages:MvvmContentPage>
